{
  "name": "Relay",
  "type": "client",
  "description": "Facebook's framework for building React applications that talk to a GraphQL backend.",
  "url": "https://github.com/facebook/relay",
  "features": {
    "capabilities": {
      "since": "-"
    },
    "deprecated-objects": {
      "since": "-"
    },
    "directives-on-directives": {
      "since": "-"
    },
    "executable-documents-descriptions": {
      "since": "-",
