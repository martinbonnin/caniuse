{
  "name": "Apollo Router",
  "type": "gateway",
  "description": "A configurable, high-performance routing runtime for Apollo Federation",
  "url": "https://github.com/apollographql/router",
  "features": {
    "capabilities": {
      "since": "-"
    },
    "deprecated-objects": {
      "since": "-"
    },
    "directives-on-directives": {
      "since": "-"
    },
    "executable-documents-descriptions": {
      "since": "-"
    },
    "fragment-arguments": {
      "since": "-"
    },
    "graphql-response+json": {
      "since": "-",
      "note": "[issue](https://github.com/apollographql/router/issues/6851)"
    },
    "on-error": {
      "since": "-"
    },
    "one-of": {
      "since": "-",
      "note": "Requires support in apollo-rs ([pr](https://github.com/apollographql/apollo-rs/pull/1030))"
    },
    "semantic-introspection": {
      "since": "-"
    },
    "semantic-non-null": {
      "since": "-"
    },
    "defer": {
      "since": "1.8.0 (partial)",
      "note": "Apollo Router only supports the [`incremental:0.1` spec](https://specs.apollo.dev/incremental/v0.1/) ([doc](https://www.apollographql.com/docs/graphos/routing/operations/defer))"
    },
    "stream": {
      "since": "-"
    },
    "http-batching": {
      "since": "2.6.0",
      "note": "[doc](https://www.apollographql.com/docs/graphos/routing/performance/query-batching)"
    }
  }
}
