{
  "name": "Apollo iOS",
  "type": "client",
  "description": "A GraphQL client for iOS that returns results as query-specific Swift types, and integrates with Xcode to show your Swift source and GraphQL side by side, with inline validation errors.",
  "url": "https://github.com/apollographql/apollo-ios",
  "features": {
    "capabilities": {
      "since": "n/a",
      "note": "There is no server capability so far that could justify adding support in Apollo Client"
    },
    "deprecated-objects": {
      "since": "-",
      "note": "Requires support in GraphQL.js"
    },
    "directives-on-directives": {
      "since": "-",
      "note": "Requires support in GraphQL.js"
    },
    "executable-documents-descriptions": {
      "since": "-",
      "note": "Requires support in GraphQL.js"
    },
    "fragment-arguments": {
      "since": "-",
      "note": "Requires support in GraphQL.js"
    },
    "graphql-response+json": {
      "since": "1.16.1"
    },
    "on-error": {
      "since": "-"
    },
    "one-of": {
      "since": "1.16.0",
      "note": "[pr](https://github.com/apollographql/apollo-ios-dev/pull/537), [release](https://github.com/apollographql/apollo-ios/releases/tag/1.16.0)"
    },
    "semantic-introspection": {
      "since": "n/a",
      "note": "Not applicable to clients."
    },
    "semantic-non-null": {
      "since": "-"
    },
    "defer": {
      "since": "1.14.0 (partial)",
      "note": "Apollo iOS only supports the [`incremental:0.1` spec](https://specs.apollo.dev/incremental/v0.1/) ([doc](https://www.apollographql.com/docs/ios/fetching/defer))"
    },
    "stream": {
      "since": "-",
      "note": "[issue](https://github.com/apollographql/apollo-ios/issues/2269)"
    },
    "field-extensions": {
      "since": "?"
    },
    "http-batching": {
      "since": "?"
    }
  }
}
