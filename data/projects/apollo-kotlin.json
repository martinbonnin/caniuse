{
  "name": "Apollo Kotlin",
  "type": "client",
  "description": "A strongly-typed, caching GraphQL client for the JVM, Android, and Kotlin multiplatform.",
  "url": "https://github.com/apollographql/apollo-kotlin",
  "features": {
    "capabilities": {
      "since": "5.0.0-alpha.5"
    },
    "graphql-response+json": {
      "since": "4.1.0",
      "note": "[Apollo Kotlin pull request](https://github.com/apollographql/apollo-kotlin/pull/6170)"
    },
    "on-error": {
      "since": "5.0.0-alpha.5"
    },
    "one-of": {
      "since": "4.0.0"
    },
    "deprecated-objects": {
      "since": null
    },
    "directives-on-directives": {
      "since": "5.0.0-alpha.4"
    },
    "executable-documents-descriptions": {
      "since": "4.0.0"
    },
    "fragment-arguments": {
      "since": "5.0.0-alpha.5"
    },
    "semantic-introspection": {
      "since": null
    },
    "semantic-non-null": {
      "since": "4.0.0"
    }
  }
}
