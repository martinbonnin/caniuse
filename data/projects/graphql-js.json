{
  "name": "GraphQL.js",
  "type": "server",
  "description": "The reference implementation of the GraphQL specification, designed for running GraphQL in a Node.js environment.",
  "url": "https://github.com/graphql/graphql-js",
  "features": {
    "graphql-response+json": {
      "since": "n/a",
      "note": "graphql-js is transport agnostic."
    },
    "one-of": {
      "since": "16.9.0"
    },
    "capabilities": {
      "since": "-",
      "note": "[pr](https://github.com/graphql/graphql-js/pull/4523)"
    },
    "deprecated-objects": {
      "since": "-",
      "note": "[pr](https://github.com/graphql/graphql-js/pull/3818)"
    },
    "directives-on-directives": {
      "since": "-",
      "note": "[pr](https://github.com/graphql/graphql-js/pull/4521)"
    },
    "executable-documents-descriptions": {
      "since": "16.12.0",
      "note": "[pr](https://github.com/graphql/graphql-js/pull/4482)"
    },
    "fragment-arguments": {
      "since": "17.0.0-alpha.8",
      "note": "[pr](https://github.com/graphql/graphql-js/pull/4015)"
    },
    "on-error": {
      "since": "-",
      "note": "[pr](https://github.com/graphql/graphql-js/pull/4364)"
    },
    "semantic-introspection": {
      "since": "-"
    },
    "semantic-non-null": {
      "since": "n/a",
      "note": "`@semanticNonNull` is not a built-in directive and will probably never be. It's only used as a transitional phase while tools migrate to `onError: NULL`."
    },
    "defer": {
      "since": "?"
    },
    "stream": {
      "since": "?"
    }
  }
}
