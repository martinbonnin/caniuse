{
  "name": "gql.tada",
  "type": "tool",
  "description": "Magical GraphQL query engine for TypeScript.",
  "url": "https://github.com/0no-co/gql.tada",
  "features": {
    "capabilities": {
      "since": "-"
    },
    "deprecated-objects": {
      "since": "-"
    },
    "directives-on-directives": {
      "since": "-"
    },
    "executable-documents-descriptions": {
      "since": "1.9.0",
      "note": "[pr](https://github.com/0no-co/gql.tada/pull/479)"
    },
    "fragment-arguments": {
      "since": "-"
    },
    "graphql-response+json": {
      "since": "n/a",
      "note": "gql.tada is transport agnostic."
    },
    "on-error": {
      "since": "-"
    },
    "one-of": {
      "since": "1.7.0",
      "note": "[pr](https://github.com/0no-co/gql.tada/pull/284)"
    },
    "semantic-introspection": {
      "since": "-"
    },
    "semantic-non-null": {
      "since": "-",
      "note": "gql.tada supports its own client-controlled nullability directives (`@_required` and `@_optional`) since 1.1.0, but not semantic non-null."
    },
    "defer": {
      "since": "1.0.0 (partial)",
      "note": "gql.tada is transport agnostic, but types deferred fragment spreads as optional. Related fixes shipped in 1.8.0 and 1.8.3."
    },
    "stream": {
      "since": "n/a",
      "note": "gql.tada is transport agnostic; `@stream` delivery is handled by the client/server transport."
    },
    "field-extensions": {
      "since": "-"
    },
    "http-batching": {
      "since": "n/a",
      "note": "gql.tada is transport agnostic."
    },
    "automatic-persisted-queries": {
      "since": "n/a",
      "note": "gql.tada is transport agnostic."
    },
    "deprecated-input-values": {
      "since": "",
      "note": ""
    },
    "directives-on-variable-definitions": {
      "since": "",
      "note": ""
    },
    "interfaces-on-interfaces": {
      "since": "",
      "note": ""
    },
    "mutations": {
      "since": "",
      "note": ""
    },
    "persisted-documents": {
      "since": "n/a",
      "note": "gql.tada is transport agnostic."
    },
    "queries": {
      "since": "",
      "note": ""
    },
    "repeatable-directives": {
      "since": "",
      "note": ""
    },
    "specified-by": {
      "since": "",
      "note": ""
    },
    "subscriptions": {
      "since": "",
      "note": ""
    }
  }
}
