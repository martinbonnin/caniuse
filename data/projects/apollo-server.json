{
  "name": "Apollo Server",
  "type": "server",
  "description": "A GraphQL server from Apollo that works with any Node.js HTTP framework",
  "url": "https://github.com/apollographql/apollo-server",
  "features": {
    "graphql-response+json": {
      "since": "13.0.0",
      "note": "[Apollo Server pull request](https://github.com/apollographql/apollo-server/pull/6827)"
    },
    "capabilities": {
      "since": "?"
    },
    "deprecated-objects": {
      "since": "?"
    },
    "directives-on-directives": {
      "since": "?"
    },
    "executable-documents-descriptions": {
      "since": "?"
    },
    "fragment-arguments": {
      "since": "?"
    },
    "on-error": {
      "since": "?"
    },
    "one-of": {
      "since": "?"
    },
    "semantic-introspection": {
      "since": "?"
    },
    "semantic-non-null": {
      "since": "?"
    },
    "defer": {
      "since": "5.1.0",
      "note": "`@defer` support requires `graphql-js:17.0.0-alpha.9` ([doc](https://www.apollographql.com/docs/apollo-server/workflow/requests#incremental-delivery-experimental))"
    },
    "stream": {
      "since": "5.1.0",
      "note": "`@stream` support requires `graphql-js:17.0.0-alpha.9` ([doc](https://www.apollographql.com/docs/apollo-server/workflow/requests#incremental-delivery-experimental))"
    },
    "field-extensions": {
      "since": "?"
    },
    "http-batching": {
      "since": "?"
    }
  }
}
